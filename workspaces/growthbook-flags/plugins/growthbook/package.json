{
  "name": "@backstage-community/plugin-growthbook",
  "version": "0.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "backstage-community-growthbook",
    "pluginPackage": "@backstage-community/plugin-growthbook",
