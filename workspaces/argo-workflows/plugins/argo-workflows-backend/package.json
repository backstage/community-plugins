{
  "name": "@backstage-community/plugin-argo-workflows-backend",
  "description": "Backend plugin for the argo-workflows plugin",
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "argo-workflows",
    "pluginPackage": "@backstage-community/plugin-argo-workflows-backend",
    "pluginPackages": [
      "@backstage-community/plugin-argo-workflows",
      "@backstage-community/plugin-argo-workflows-backend",
      "@backstage-community/plugin-argo-workflows-common",
      "@backstage-community/plugin-argo-workflows-react"
    ]
  },
  "configSchema": "config.d.ts",
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test --passWithNoTests --coverage",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage-community/plugin-argo-workflows-common": "workspace:^",
    "@backstage/backend-plugin-api": "backstage:^",
    "@backstage/config": "backstage:^",
    "@backstage/errors": "backstage:^",
    "@backstage/plugin-kubernetes-common": "backstage:^",
    "@backstage/plugin-kubernetes-node": "backstage:^",
    "express": "^4.17.1",
    "express-promise-router": "^4.1.0",
    "node-fetch": "^2.6.7"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "backstage:^",
    "@backstage/cli": "backstage:^",
    "@types/express": "^4.17.6",
    "@types/node-fetch": "^2.6.4",
    "@types/supertest": "^7.0.0",
    "supertest": "^7.0.0"
  },
  "files": [
    "dist",
    "config.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/backstage/community-plugins",
    "directory": "workspaces/argo-worflows/plugins/argo-workflows-backend"
  },
  "keywords": [
    "backstage",
    "plugin",
    "argo-workflows"
  ]
}
