  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "@backstage/test-utils": "backstage:^",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "^18",
    "react": "^17.0.0 || ^18.0.0"
  },
