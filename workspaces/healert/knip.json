{
  "workspaces": {
    ".": {},
    "{packages,plugins}/*": {
      "entry": [
        "dev/**/*.{ts,tsx}",
        "src/index.{ts,tsx}"
      ],
      "ignore": [
        ".eslintrc.js",
        "config.d.ts",
        "knexfile.js",
        "node_modules/**",
        "dist/**",
        "{fixtures,migrations,templates}/**",
        "src/tests/transforms/__fixtures__/**"
      ]
    }
  },
  "jest": {
    "entry": [
      "src/setupTests.ts",
      "src/**/*.test.{ts,tsx}"
    ]
  },
  "storybook": {
    "entry": "src/components/**/*.stories.tsx"
  },
  "ignoreDependencies": [
    "@types/react",
    "@types/jest",
    "@internal/.*",
    "@backstage/cli",
    "@backstage/theme"
  ]
}